        <div x-show="modalOpen" x-cloak class="relative z-50">
            <div x-show="modalOpen" x-transition.opacity class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity"></div>
            
            <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
                <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                    <div x-show="modalOpen"
                         x-transition:enter="ease-out duration-300"
                         x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                         x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                         @click.outside="modalOpen = false"
                         class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-4xl border border-gray-100">
                        
                        <div class="bg-gray-50 flexflex-col h-full">
                            <!-- Premium AI Header -->
                            <div class="bg-slate-900 px-6 py-5 flex justify-between items-center text-white relative overflow-hidden border-b-4 border-indigo-500">
                                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay"></div>
                                <div class="relative z-10 flex items-center">
                                    <div class="w-10 h-10 rounded-lg bg-indigo-500/30 border border-indigo-400/50 flex items-center justify-center mr-4">
                                        <svg class="w-6 h-6 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-black tracking-tight text-white leading-none">Evaluasi Keberhasilan Panen</h3>
                                        <p class="text-indigo-300 text-xs mt-1 font-mono uppercase tracking-widest">Jalur Aturan Keputusan</p>
                                    </div>
                                </div>
                                <button type="button" @click="modalOpen = false" class="text-slate-400 hover:text-white transition relative z-10 bg-slate-800 p-2 rounded-xl border border-slate-700 hover:bg-slate-700">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                                </button>
                            </div>
                            
                            <!-- Modal Body grid -->
                            <div class="p-6 grid grid-cols-1 md:grid-cols-3 gap-6 bg-gray-50">
                                
                                <!-- LEFT COLUMN: Data Overview (A, B, C, D) -->
                                <div class="col-span-1 md:col-span-1 space-y-4">
                                    <!-- A: Identitas -->
                                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
                                        <div class="text-center pb-4 border-b border-gray-100">
                                            <div class="w-16 h-16 rounded-full bg-slate-100 border-2 border-slate-200 flex items-center justify-center text-2xl font-bold text-slate-700 mx-auto mb-2" x-text="safelyGetStudentName(activeData)[0]"></div>
                                            <h4 class="font-bold text-gray-900" x-text="safelyGetStudentName(activeData)"></h4>
                                            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-indigo-50 text-indigo-600 mt-1 inline-block">Kelas XIII (Mock)</span>
                                        </div>
                                        <div class="pt-3">
                                            <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest block mb-1">Objek Budidaya</span>
                                            <span class="text-sm font-bold text-emerald-600 border border-emerald-100 bg-emerald-50 px-2 py-1 rounded w-full block text-center" x-text="activeData.jenis_tanaman"></span>
                                        </div>
                                    </div>

                                    <!-- B, C, D Combined Timeline style -->
                                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 relative">
                                        <div class="absolute left-6 top-6 bottom-6 w-0.5 bg-gray-100"></div>
                                        
                                        <!-- Penanaman -->
                                        <div class="relative pl-6 pb-4">
                                            <div class="absolute left-[-5px] top-1 w-3 h-3 rounded-full bg-gray-300 ring-4 ring-white"></div>
                                            <h5 class="text-xs font-bold text-gray-800 uppercase">Fase Tanam</h5>
                                            <p class="text-xs text-gray-500 mt-1">Bibit Awal: <span class="font-bold text-gray-700" x-text="activeData.jml_bibit"></span></p>
                                            <p class="text-[10px] text-gray-400" x-text="'Media: ' + (activeData.kondisi_tanah || 'N/A')"></p>
                                        </div>

                                        <!-- Pemeliharaan -->
                                        <div class="relative pl-6 pb-4">
                                            <div class="absolute left-[-5px] top-1 w-3 h-3 rounded-full bg-blue-400 ring-4 ring-white"></div>
                                            <h5 class="text-xs font-bold text-gray-800 uppercase">Treatment Mingguan</h5>
                                            <p class="text-[10px] text-gray-500 mt-1 italic border-l-2 border-blue-200 pl-2">Sistem merekam data checklist rutinitas tersentralisasi di log evaluasi.</p>
                                        </div>

                                        <!-- Panen -->
                                        <div class="relative pl-6">
                                            <div class="absolute left-[-5px] top-1 w-3 h-3 rounded-full bg-orange-400 ring-4 ring-white"></div>
                                            <h5 class="text-xs font-bold text-gray-800 uppercase">Fase Panen</h5>
                                            <p class="text-xs text-gray-500 mt-1">Total Bobot: <span class="font-bold text-orange-600" x-text="safelyGetPanenBobot(activeData) + ' Kg'"></span></p>
                                            <p class="text-[10px] font-medium text-gray-500" x-text="'Rasio: ' + safelyGetPanenHidup(activeData) + ' Hidup vs ' + safelyGetPanenMati(activeData) + ' Mati'"></p>
                                        </div>
                                    </div>
                                </div>

                                <!-- RIGHT COLUMN: AI Analysis (E, F) -->
                                <div class="col-span-1 md:col-span-2 space-y-4 flex flex-col">
                                    
                                    <!-- E. Hasil AI Banner -->
                                    <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
                                        <div>
                                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Keputusan Akhir Algoritma</p>
                                            <h2 class="text-2xl font-black" :class="aiData.nilai_prediksi > 60 ? 'text-emerald-600' : 'text-red-600'" x-text="activeData.evaluasi ? activeData.evaluasi.hasil_klasifikasi : 'Tidak Valid'"></h2>
                                        </div>
                                        <div class="w-16 h-16 rounded-full border-4 flex items-center justify-center shadow-inner" :class="aiData.nilai_prediksi > 60 ? 'border-emerald-50 bg-emerald-500' : 'border-red-50 bg-red-500'">
                                            <span class="text-white font-black text-lg" x-text="aiData.tingkat_persen + '%'"></span>
                                        </div>
                                    </div>

                                    <!-- Faktor & Aturan -->
                                    <div class="bg-slate-900 rounded-xl shadow-sm border border-slate-800 p-5 flex-1 relative overflow-hidden">
                                        <div class="absolute top-0 right-0 p-4 opacity-10">
                                            <svg class="w-24 h-24 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                                        </div>
                                        
                                        <h4 class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest mb-4 flex items-center">
                                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287-.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"></path></svg>
                                            Inference Reasonings
                                        </h4>
                                        
                                        <div class="space-y-3 relative z-10">
                                            <div class="bg-white/5 border border-white/10 rounded-lg p-3">
                                                <p class="text-[11px] text-slate-400 mb-1 font-mono">>>> EXTRACTED_FACTORS</p>
                                                <ul>
                                                    <template x-for="faktor in aiData.faktor_utama">
                                                        <li class="text-sm text-yellow-300 font-bold" x-text="faktor"></li>
                                                    </template>
                                                </ul>
                                            </div>
                                            
                                            <div class="bg-white/5 border border-white/10 rounded-lg p-3">
                                                <p class="text-[11px] text-slate-400 mb-1 font-mono">>>> LOGICAL_RULES</p>
                                                <ul class="list-disc list-inside text-sm text-indigo-100 font-medium space-y-1">
                                                    <template x-for="rule in aiData.aturan">
                                                        <li x-text="rule"></li>
                                                    </template>
                                                    <li x-show="!aiData.aturan || aiData.aturan.length === 0" class="text-gray-500 italic">No rules parsed.</li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- F. Rekomendasi -->
                                    <div class="bg-white p-4 rounded-xl shadow-sm border border-indigo-100">
                                        <h4 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3 flex items-center">
                                            <svg class="w-4 h-4 mr-1 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
                                            Rekomendasi Cerdas Sistem
                                        </h4>
                                        <div class="space-y-2">
                                            <template x-for="rec in aiData.rekomendasi">
                                                <div class="flex items-start">
                                                    <svg class="w-4 h-4 mr-2 text-indigo-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path></svg>
                                                    <p class="text-sm text-gray-600 font-medium" x-text="rec"></p>
                                                </div>
                                            </template>
                                            <p x-show="!aiData.rekomendasi || aiData.rekomendasi.length === 0" class="text-sm text-gray-400 italic">Sistem membutuhkan data penanaman, pemeliharaan, dan panen yang lengkap untuk memberikan rekomendasi.</p>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            
                            <!-- Modal Footer -->
                            <div class="bg-gray-100 border-t border-gray-200 px-6 py-4 flex justify-end items-center rounded-b-2xl">
                                <button class="text-sm font-bold text-indigo-600 hover:text-indigo-800 px-4 mr-auto underline underline-offset-4 flex items-center" onclick="alert('Mencetak PDF Logic Blueprint...');">
                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                                    Cetak PDF (Mock)
                                </button>
                                <button type="button" @click="modalOpen = false" class="inline-flex justify-center items-center rounded-xl bg-slate-800 px-6 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-slate-900 transition focus:outline-none">
                                    Tutup Diagnostic
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Script Injection -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('evaluasiSistem', () => ({
                isSubmitting: false,
                modalOpen: false,
                activeData: {},
                aiData: { aturan: [], rekonstruksi: [], faktor_utama: '', nilai_prediksi: 0, tingkat_persen: '-' },

                safelyGetStudentName(data) {
                    return data && data.siswa ? data.siswa.name : 'Unknown';
                },
                safelyGetPanenBobot(data) {
                    return data && data.panen ? data.panen.bobot_panen : 0;
                },
                safelyGetPanenHidup(data) {
                    return data && data.panen ? data.panen.tanaman_hidup : 0;
                },
                safelyGetPanenMati(data) {
                    return data && data.panen ? data.panen.tanaman_mati : 0;
                },

                openDetailModal(itemProps) {
                    this.activeData = itemProps;

                    const evaluasi = itemProps.evaluasi || {};

                    let rincian = evaluasi.rincian_aturan || {};

                    if (typeof rincian === 'string') {
                        try {
                            rincian = JSON.parse(rincian);
                        } catch (e) {
                            rincian = {};
                        }
                    }

                    let faktor = evaluasi.faktor_utama || [];
                    if (typeof faktor === 'string') {
                        try {
                            faktor = JSON.parse(faktor);
                        } catch (e) {
                            faktor = [faktor];
                        }
                    }

                    let rekomendasi = evaluasi.rekomendasi || [];
                    if (typeof rekomendasi === 'string') {
                        try {
                            rekomendasi = JSON.parse(rekomendasi);
                        } catch (e) {
                            rekomendasi = [rekomendasi];
                        }
                    }

                    this.aiData = {
                        skor: evaluasi.skor || 0,
                        tingkat_persen: evaluasi.skor || 0,
                        hasil_klasifikasi: evaluasi.hasil_klasifikasi || 'Belum Dievaluasi',
                        persentase_hidup: evaluasi.persentase_hidup || 0,
                        persentase_hasil: evaluasi.persentase_hasil || 0,
                        faktor_utama: faktor,
                        rekomendasi: rekomendasi,
                        rincian_aturan: rincian,
                        aturan: [
                            rincian.rule_terpakai || rincian.rule || 'Aturan belum tercatat'
                        ],
                    };

                    this.modalOpen = true;
                }
            }));
        });
        
        // ChartJS Initializer (Only loads if stats are present aka Guru mode)
        document.addEventListener("DOMContentLoaded", function() {
            @if(isset($stats))
            const ctxEval = document.getElementById('evalChart');
            if (ctxEval) {
                new Chart(ctxEval.getContext('2d'), {
                    type: 'pie', // using pie instead of donut for variance
                    data: {
                        labels: ['Berhasil', 'Cukup', 'Gagal'],
                        datasets: [{
                            data: [{{ $stats['berhasil'] ?? 0 }}, {{ $stats['cukup'] ?? 0 }}, {{ $stats['gagal'] ?? 0 }}],
                            backgroundColor: ['#10B981', '#EAB308', '#F43F5E'],
                            borderWidth: 2,
                            borderColor: '#4f46e5', // indigo matching background panel
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { 
                                position: 'bottom', 
                                labels: { color: '#e0e7ff', boxWidth: 10, font: { family: 'Inter', size: 10 } }
                            }
                        }
                    }
                });
            }
            @endif
        });
    </script>
</x-app-layout>
